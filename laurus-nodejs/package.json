{
  "name": "@laurus/nodejs",
  "version": "0.4.2",
  "description": "Node.js bindings for the Laurus search library",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "laurus-nodejs",
    "targets": [
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release -p laurus-nodejs",
    "build:debug": "napi build --platform -p laurus-nodejs",
    "test": "vitest run",
    "artifacts": "napi artifacts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mosuka/laurus"
  },
  "keywords": [
    "search",
    "vector",
    "lexical",
    "hybrid",
    "full-text-search",
    "napi-rs",
    "rust"
  ],
  "author": "Minoru Osuka",
  "license": "MIT",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "optionalDependencies": {
    "@laurus/nodejs-darwin-x64": "0.4.2",
    "@laurus/nodejs-darwin-arm64": "0.4.2",
    "@laurus/nodejs-linux-x64-gnu": "0.4.2",
    "@laurus/nodejs-linux-arm64-gnu": "0.4.2",
    "@laurus/nodejs-win32-x64-msvc": "0.4.2",
    "@laurus/nodejs-win32-arm64-msvc": "0.4.2"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "vitest": "^4.1.1"
  }
}
